{
  "extends": "./tsconfig.app.json",
  "outDir": "./dist",
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.node.json"
    }
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts",],
  "exclude": ["node_modules", "dist", "**/*.d.ts"]
}
